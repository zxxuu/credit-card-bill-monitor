# Telegram Bot 配置
# 获取方式：通过 @BotFather 创建 bot 并获取 token
BILL_BOT_TOKEN=your_telegram_bot_token_here

# Telegram 接收消息的 Chat ID
# 获取方式：发送消息给 bot，然后访问 https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_HOME_CHANNEL=your_chat_id_here

# QQ邮箱配置（用于接收账单邮件）
# 需要在 QQ邮箱设置中开启 IMAP 服务并获取授权码
QQ_EMAIL=your_qq_email@qq.com
QQ_IMAP_AUTH_CODE=your_imap_auth_code_here
